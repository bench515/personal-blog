---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: Date;
    updatedDate?: Date;
    tags?: string[];
    image?: string;
  };
}

const { frontmatter } = Astro.props;
const currentPath = Astro.url.pathname;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogImage={frontmatter.image || "/og-default.png"}
  currentPath={currentPath}
>
  <article class="blog-post">
    <header class="post-header">
      <h1 class="post-title">{frontmatter.title}</h1>
      <div class="post-meta">
        <time datetime={frontmatter.pubDate.toISOString()}>
          {frontmatter.pubDate.toLocaleDateString("zh-CN", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        {
          frontmatter.updatedDate && (
            <span class="updated-date">
              · 更新于{" "}
              {frontmatter.updatedDate.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          )
        }
      </div>
      {
        frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="post-tags">
            {frontmatter.tags.map((tag) => (
              <a href={`${import.meta.env.BASE_URL}/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`} class="tag">
                #{tag}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <div class="post-body">
      <slot />
    </div>

    <!-- Comments -->
    <div class="post-comments" id="comments">
      <h2>评论</h2>
      <div id="giscus-container">
        <noscript>
          <p class="no-js-msg">请启用 JavaScript 以查看评论。</p>
        </noscript>
      </div>
    </div>
  </article>

  <script>
    // Giscus - replace with your own repo after creating the blog repo on GitHub
    const script = document.createElement("script");
    script.src = "https://giscus.app/client.js";
    script.setAttribute("data-repo", "bench515/personal-blog");
    script.setAttribute("data-repo-id", "R_kgDOSroFRg");
    script.setAttribute("data-category", "Announcements");
    script.setAttribute("data-category-id", "DIC_kwDOSroFRs4C-GhI");
    script.setAttribute("data-mapping", "pathname");
    script.setAttribute("data-strict", "0");
    script.setAttribute("data-reactions-enabled", "1");
    script.setAttribute("data-emit-metadata", "0");
    script.setAttribute("data-input-position", "bottom");
    script.setAttribute("data-theme", document.documentElement.classList.contains("dark") ? "dark" : "light");
    script.setAttribute("data-lang", "zh-CN");
    script.setAttribute("crossorigin", "anonymous");
    script.async = true;
    document.getElementById("giscus-container")?.appendChild(script);
  </script>
</BaseLayout>

<style>
  .blog-post {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .post-title {
    font-size: 2.25rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .post-meta {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
  }

  .updated-date {
    font-style: italic;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
  }

  .tag {
    display: inline-block;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 0.2rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 500;
    transition: background 0.2s, color 0.2s;
  }

  .tag:hover {
    background: var(--color-primary);
    color: #fff;
  }

  .post-body {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .post-body h2 {
    margin-top: 2rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-body h3 {
    margin-top: 1.5rem;
  }

  .post-body ul,
  .post-body ol {
    margin: 0.75rem 0 1rem 1.5rem;
  }

  .post-body li {
    margin-bottom: 0.35rem;
  }

  .post-body img {
    border-radius: 8px;
    margin: 1.5rem auto;
    display: block;
  }

  .post-body hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .post-comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .post-comments h2 {
    margin-bottom: 1rem;
  }

  .no-js-msg {
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-title {
      font-size: 1.6rem;
    }
  }
</style>
