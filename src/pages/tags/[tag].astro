---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tagSet = new Set<string>();
  posts
    .filter((p) => !p.data.draft)
    .forEach((p) => {
      p.data.tags?.forEach((t: string) => tagSet.add(t.toLowerCase().replace(/\s+/g, "-")));
    });

  return [...tagSet].map((tag) => ({
    params: { tag },
  }));
}

const { tag } = Astro.params;

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .filter(
    (p) =>
      p.data.tags?.some(
        (t: string) => t.toLowerCase().replace(/\s+/g, "-") === tag
      )
  )
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title={`#${tag}`} currentPath="/tags">
  <h1>🏷️ #{tag}</h1>
  <p class="subtitle">共 {posts.length} 篇文章</p>

  <div class="post-list">
    {posts.map((post) => (
      <article class="post-card">
        <a href={`/blog/${post.slug}`} class="post-card-link">
          <h3 class="post-card-title">{post.data.title}</h3>
          <p class="post-card-desc">{post.data.description}</p>
          <div class="post-card-meta">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("zh-CN", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
          </div>
        </a>
      </article>
    ))}
  </div>
</BaseLayout>

<style>
  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg-card);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px var(--color-card-hover-shadow);
  }

  .post-card-link {
    display: block;
    padding: 1.25rem 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .post-card-title {
    font-size: 1.2rem;
    margin-bottom: 0.35rem;
  }

  .post-card-desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .post-card-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
