---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="文章" currentPath="/blog">
  <h1>📚 所有文章</h1>
  <p class="subtitle">共 {posts.length} 篇文章</p>

  <!-- Search box -->
  <div id="search" class="search-box"></div>

  {
    posts.length === 0 ? (
      <p class="no-posts">还没有文章。</p>
    ) : (
      <div class="post-list">
        {posts.map((post) => (
          <article class="post-card">
            <a href={`${import.meta.env.BASE_URL}/blog/${post.slug}`} class="post-card-link">
              <h3 class="post-card-title">{post.data.title}</h3>
              <p class="post-card-desc">{post.data.description}</p>
              <div class="post-card-meta">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("zh-CN", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
                {
                  post.data.tags.length > 0 && (
                    <span class="post-card-tags">
                      · {post.data.tags.map((t) => `#${t}`).join(" ")}
                    </span>
                  )
                }
              </div>
            </a>
          </article>
        ))}
      </div>
    )
  }
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .search-box {
    margin-bottom: 2rem;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg-card);
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px var(--color-card-hover-shadow);
  }

  .post-card-link {
    display: block;
    padding: 1.25rem 1.5rem;
    color: inherit;
    text-decoration: none;
  }

  .post-card-title {
    font-size: 1.2rem;
    margin-bottom: 0.35rem;
  }

  .post-card-desc {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .post-card-meta {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .no-posts {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }
</style>
